nBEE = 5;
nNIGHT = 4;
MW = 6;
min_ward = [| N, 3, 0, 0, 0, 0      % min # of total, BEETLE, BUTTERFLY, DRAGONFLY, BEE staffs at N
            | A, 0, 1, 1, 1, 1      % min # of total, BEETLE, BUTTERFLY, DRAGONFLY, BEE staffs at A
            | P, 0, 1, 1, 1, 1|];   % min # of total, BEETLE, BUTTERFLY, DRAGONFLY, BEE staffs at P
max_rn3 = [1, 2, 2];                % max # of RN3 at N,A,P

active_constraints = [
  true, % ward request duty constraint
  true, % 5-day working + public holiday O entitlement constraint
  true, % # of contract O constraint
  false, % no weekend PP constraint (mandatory)
  true, % daily ward requirement constraint (mandatory)
  true, % normal AN constraint
  true, % at least 2 Os for 4Ns constraint (mandatory)
  false, % no triple-A/P and NPA/NPP constraint (mandatory)
  true, % at least 1 O for NW days constraint (mandatory)
  false, % requested annual leaves (mandatory)
  false, % requested long night duties (mandatory)
  true, % # of public holiday O constraint
];
